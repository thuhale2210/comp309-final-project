    <worksheet name='Recovery by Cost'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Recovery Rate by Bike Cost Range</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Bicycle_Thefts_Open_Data' name='federated.160g02i1lk09bu19ra5wj0d95gek' />
          </datasources>
          <datasource-dependencies datasource='federated.160g02i1lk09bu19ra5wj0d95gek'>
            <column caption='Bike Cost' datatype='real' name='[BIKE_COST]' role='measure' type='quantitative' />
            <column caption='Total Records' datatype='integer' name='[Calculation_2373678490672713741]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([OBJECTID])' />
            </column>
            <column caption='Total Recovered' datatype='integer' name='[Calculation_2373678490672930831]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(IF [STATUS] = &quot;RECOVERED&quot; THEN [OBJECTID] END)' />
            </column>
            <column caption='Recovery Rate' datatype='real' name='[Calculation_2373678490673053712]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_2373678490672930831] / [Calculation_2373678490672713741]' />
            </column>
            <column caption='Cost Range' datatype='string' name='[Calculation_2373678490673451026]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [BIKE_COST] &lt; 500 THEN &quot;Under $500&quot;&#13;&#10;ELSEIF [BIKE_COST] &lt; 1000 THEN &quot;$500-$1,000&quot;&#13;&#10;ELSEIF [BIKE_COST] &lt; 2000 THEN &quot;$1,000-$2,000&quot;&#13;&#10;ELSE &quot;Over $2,000&quot;&#13;&#10;END' />
            </column>
            <column caption='Objectid' datatype='integer' name='[OBJECTID]' role='measure' type='quantitative' />
            <column caption='Status' datatype='string' name='[STATUS]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_2373678490673451026]' derivation='None' name='[none:Calculation_2373678490673451026:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_2373678490672713741]' derivation='User' name='[usr:Calculation_2373678490672713741:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_2373678490673053712]' derivation='User' name='[usr:Calculation_2373678490673053712:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <manual-sort column='[federated.160g02i1lk09bu19ra5wj0d95gek].[none:Calculation_2373678490673451026:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;Under $500&quot;</bucket>
              <bucket>&quot;$500-$1,000&quot;</bucket>
              <bucket>&quot;$1,000-$2,000&quot;</bucket>
              <bucket>&quot;Over $2,000&quot;</bucket>
            </dictionary>
          </manual-sort>
          <aggregation value='true' />
        </view>
